{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "aio-cloudflare",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "aio-cloudflare",
			"database_id": "local",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "aio-cloudflare",
		},
	],
}